# CloudGraph Environment Configuration
# Copy this file to .env and customize for your environment
#
# Usage:
#   Development: docker compose up
#   Production:  docker compose -f docker-compose.prod.yml up -d

# =============================================================================
# Neo4j Database Configuration
# =============================================================================

# Neo4j username (default: neo4j)
NEO4J_USER=neo4j

# REQUIRED: set Neo4j password. Example: NEO4J_PASSWORD=$(openssl rand -base64 24)
# Neo4j password (REQUIRED - must be changed before use)
# Production: Use a strong, unique password
NEO4J_PASSWORD=<CHANGE_ME>

# =============================================================================
# CloudGraph API Configuration
# =============================================================================

# Enable/disable authentication (set to true for production!)
# Development default: false
# Production: MUST be true
AUTH_ENABLED=false

# REQUIRED: 32+ char secret. Generate: JWT_SECRET=$(openssl rand -base64 32)
# JWT secret for token signing (REQUIRED when AUTH_ENABLED=true)
# Must be at least 32 characters long
JWT_SECRET=<CHANGE_ME>

# JWT token expiry in seconds (default: 3600 = 1 hour)
JWT_EXPIRY=3600

# Allowed CORS origins (comma-separated)
# Development: localhost origins
# Production: your actual domain(s)
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Maximum query result limit
MAX_QUERY_LIMIT=10000

# =============================================================================
# Docker Image Configuration
# =============================================================================

# CloudGraph version tag for images
CLOUDGRAPH_VERSION=0.5.0

# =============================================================================
# Production-Only Settings (docker-compose.prod.yml)
# =============================================================================

# These are only used with docker-compose.prod.yml
# Uncomment and configure for production deployment:

# NEO4J_PASSWORD=your_secure_neo4j_password
# JWT_SECRET=your_32_char_minimum_jwt_secret
# AUTH_ENABLED=true
# CORS_ORIGINS=https://cloudgraph.yourdomain.com
# LOG_LEVEL=INFO
